{
  "expo": {
    "name": "GitaSaar",
    "slug": "gitasaar",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#FFF8E7",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "gitasaar",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#FFF8E7",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gitasaar.app",
      "splash": {
        "image": "./assets/splash-icon.png",
        "backgroundColor": "#FFF8E7",
        "resizeMode": "contain"
      },
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSMicrophoneUsageDescription": "GitaSaar needs microphone access for voice input.",
        "NSCameraUsageDescription": "GitaSaar needs camera access to update your profile photo.",
        "NSPhotoLibraryUsageDescription": "GitaSaar needs photo library access to select your profile photo.",
        "NSPhotoLibraryAddUsageDescription": "GitaSaar needs photo library access to save shared cards."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8E7"
      },
      "package": "com.gitasaar.app",
      "versionCode": 1,
      "splash": {
        "image": "./assets/splash-icon.png",
        "backgroundColor": "#FFF8E7",
        "resizeMode": "contain"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-sharing",
      "expo-image",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C28840",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GitaSaar needs access to your photos to update your profile picture.",
          "cameraPermission": "GitaSaar needs camera access to take a profile photo."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow GitaSaar to access your photos.",
          "savePhotosPermission": "Allow GitaSaar to save shared verse cards."
        }
      ],
      "expo-av"
    ],
    "extra": {
      "eas": {
        "projectId": "36896040-54e1-40e1-b5ba-e5af0c467dfa"
      }
    }
  }
}