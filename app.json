{
  "expo": {
    "name": "GitaSaar",
    "backgroundColor": "#FDF8EF",
    "slug": "gitasaar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FFF8E7",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gitasaar.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF8E7"
      },
      "package": "com.gitasaar.app"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-sharing",
      "expo-image",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "36896040-54e1-40e1-b5ba-e5af0c467dfa"
      }
    }
  }
}